---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL;
const path = (value: string) => `${base}${value.replace(/^\//, "")}`;
const packages = (await getCollection("packages")).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="H47 Digital | Monthly Marketing Support"
  description="Monthly marketing support for owner-led businesses, from consistent social media presence to strategic ongoing marketing partnerships."
>
  <main class="index-page">
    <section class="index-hero">
      <p class="kicker">H47 Digital</p>
      <h1>Monthly marketing support built around where your business is now.</h1>
      <p>
        Whether you need a more consistent social media presence, stronger campaign momentum, or a more strategic ongoing marketing partner, H47 Digital gives your business a clearer monthly rhythm.
      </p>
    </section>
    <section class="package-cards" aria-label="Landing pages">
      {packages.map((item) => (
        <a class={`package-card theme-${item.data.theme}`} href={path(`${item.data.pageSlug}/`)}>
          <div>
            <span>{item.data.packageName}</span>
            <h2>{item.data.title}</h2>
            <p>{item.data.trust}</p>
          </div>
          <strong class="card-button">View {item.data.packageName}</strong>
        </a>
      ))}
    </section>
  </main>
</BaseLayout>
